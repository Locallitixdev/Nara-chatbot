# ═══════════════════════════════════════════════════════════════
#  NARA AI Assistant — Docker Environment
#  Copy ke .env.docker dan sesuaikan nilainya
# ═══════════════════════════════════════════════════════════════

# ─── Port Mapping (semua non-standard) ────────────────────────
FRONTEND_PORT=8391
OLLAMA_PORT=11434

# ─── Ollama Configuration ────────────────────────────────────
OLLAMA_MODEL=llama3.2:1b
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2

# ─── OpenClaw (opsional) ─────────────────────────────────────
OPENCLAW_URL=http://127.0.0.1:9847
OPENCLAW_TOKEN=

# ─── App Metadata ────────────────────────────────────────────
APP_NAME=NARA AI Assistant
APP_VERSION=1.0.0
