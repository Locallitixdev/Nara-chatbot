# ═══════════════════════════════════════════════════════════════
#  NARA AI Assistant — Docker Environment
#  Copy ke .env.docker dan sesuaikan nilainya
# ═══════════════════════════════════════════════════════════════

# ─── Port Mapping (non-standard) ─────────────────────────────
FRONTEND_PORT=8391

# ─── Ollama (berjalan di host, bukan container) ──────────────
OLLAMA_MODEL=llama3.2:1b

# ─── OpenClaw (opsional) ─────────────────────────────────────
OPENCLAW_URL=http://127.0.0.1:9847
OPENCLAW_TOKEN=

# ─── App Metadata ────────────────────────────────────────────
APP_NAME=NARA AI Assistant
APP_VERSION=1.0.0
